# ====== Core ======
PROJECT_NAME=CreatorHUB
ENV=prod

# ====== Database ======
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

# ====== Auth ======
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080

# ====== Storage (inside containers) ======
UPLOADS_DIR=/data/uploads
CACHE_DIR=/data/cache
EXPORTS_DIR=/data/exports

# ====== Redis / Worker ======
REDIS_URL=redis://redis:6379/0

# ====== Ollama ======
OLLAMA_URL=http://ollama:11434
OLLAMA_TEXT_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=moondream

# ====== Image Hunt (open sources only, no keys) ======
IMAGE_HUNT_DEFAULT_SOURCES=wikimedia,openverse
OPENVERSE_API_BASE=https://api.openverse.engineering/v1

# ====== Frontend ======
VITE_API_BASE=/api

# ====== CORS ======
CORS_ORIGINS=

# ====== Logging ======
LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=INFO
UVICORN_ACCESS_LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_TO_STDOUT=true
LOG_TO_FILE=false
LOG_DIR=/data/logs
LOG_FILE_NAME=application.log
LOG_RETENTION_DAYS=30
SECURITY_LOG_LEVEL=WARNING
SECURITY_LOG_TO_SEPARATE_FILE=true
SECURITY_LOG_FILE_NAME=security-events.log
SECURITY_LOG_RETENTION_DAYS=90
SECURITY_LOG_PROPAGATE_TO_ROOT=true

# ====== Observability ======
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_METRICS_PATH=/health/metrics
OBSERVABILITY_MONITOR_ENABLED=true
OBSERVABILITY_MONITOR_INTERVAL_SECONDS=30
ALERT_DB_FAILURE_CONSECUTIVE=3
ALERT_REDIS_FAILURE_CONSECUTIVE=3
ALERT_WORKER_FAILURE_CONSECUTIVE=3
ALERT_QUEUE_LENGTH_WARN=100
ALERT_QUEUE_LENGTH_CRITICAL=500
ALERT_FAILED_JOBS_CRITICAL=20
OTEL_ENABLED=false
OTEL_SERVICE_NAME=creatorhub-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SAMPLE_RATIO=0.2

# ====== Admin bootstrap ======
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=