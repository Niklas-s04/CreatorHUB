# ====== Core ======
PROJECT_NAME=CreatorHUB
ENV=prod

# ====== Database ======
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

# ====== Auth ======
JWT_SECRET=
BOOTSTRAP_ADMIN_PASSWORD=
JWT_EXPIRE_MINUTES=10080

# ====== Storage (inside containers) ======
UPLOADS_DIR=/data/uploads
CACHE_DIR=/data/cache
EXPORTS_DIR=/data/exports

# ====== Redis / Worker ======
REDIS_URL=redis://redis:6379/0

# ====== Ollama ======
OLLAMA_URL=http://ollama:11434
OLLAMA_TEXT_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=moondream

# ====== Image Hunt (open sources only, no keys) ======
IMAGE_HUNT_DEFAULT_SOURCES=wikimedia,openverse
OPENVERSE_API_BASE=https://api.openverse.engineering/v1

# ====== Frontend ======
VITE_API_BASE=/api

# ====== CORS ======
CORS_ORIGINS=

# ====== Logging ======
LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=INFO
JSON_SECRET=
UVICORN_ACCESS_LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_TO_STDOUT=true
LOG_TO_FILE=false
LOG_DIR=/data/logs
LOG_FILE_NAME=application.log
LOG_RETENTION_DAYS=30
SECURITY_LOG_LEVEL=WARNING
SECURITY_LOG_TO_SEPARATE_FILE=true
SECURITY_LOG_FILE_NAME=security-events.log
SECURITY_LOG_RETENTION_DAYS=90
SECURITY_LOG_PROPAGATE_TO_ROOT=true

# ====== Observability ======
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_METRICS_PATH=/health/metrics
OBSERVABILITY_MONITOR_ENABLED=true
OBSERVABILITY_MONITOR_INTERVAL_SECONDS=30
ALERT_DB_FAILURE_CONSECUTIVE=3
ALERT_REDIS_FAILURE_CONSECUTIVE=3
ALERT_WORKER_FAILURE_CONSECUTIVE=3
ALERT_QUEUE_LENGTH_WARN=100
ALERT_QUEUE_LENGTH_CRITICAL=500
ALERT_FAILED_JOBS_CRITICAL=20
OTEL_ENABLED=false
OTEL_SERVICE_NAME=creatorhub-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SAMPLE_RATIO=0.2

# ====== Admin bootstrap ======
BOOTSTRAP_ADMIN_USERNAME=admin

# ====== Auth Cookie Security ======
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict
AUTH_COOKIE_DOMAIN=
CSRF_COOKIE_NAME=creatorhub_csrf
SECURITY_SENSITIVE_ACTION_CONFIRMATION_REQUIRED=false

# ====== Rate Limiting ======
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_GLOBAL=240
RATE_LIMIT_AUTH=10

# ====== Outbound Request Limits ======
OUTBOUND_CONNECT_TIMEOUT_SECONDS=5
OUTBOUND_READ_TIMEOUT_SECONDS=20
OUTBOUND_MAX_RESPONSE_BYTES=8388608
OUTBOUND_MAX_REDIRECTS=2
OUTBOUND_REQUIRE_HTTPS=true
OUTBOUND_BLOCK_PRIVATE_RANGES=true
OUTBOUND_ALLOWED_PORTS=443

# ====== File Upload Limits ======
UPLOAD_ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp,.gif
UPLOAD_ALLOWED_PDF_EXTENSIONS=.pdf
UPLOAD_MAX_IMAGE_BYTES=8388608
UPLOAD_MAX_PDF_BYTES=15728640
UPLOAD_MAX_IMAGE_WIDTH=8000
UPLOAD_MAX_IMAGE_HEIGHT=8000
UPLOAD_MAX_IMAGE_PIXELS=30000000